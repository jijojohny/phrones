# =============================================================================
# Phronesis — Environment Variables (copy to .env and fill in values)
# See requirement.md for full credential inventory.
# NEVER commit .env to git.
# =============================================================================

# --- Network: 0G Galileo Testnet ---
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
OG_EXPLORER_URL=https://chainscan-galileo.0g.ai
OG_FAUCET_URL=https://faucet.0g.ai

# --- Network: 0G Mainnet (leave empty until production) ---
# OG_RPC_URL_MAINNET=https://evmrpc.0g.ai
# OG_CHAIN_ID_MAINNET=16661

# --- Network: Polygon (Polymarket) ---
POLYGON_RPC_URL=https://polygon-rpc.com
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=

# --- Deployer wallets ---
# Testnet: used for 0G deploys, storage fees, compute funding
DEPLOYER_PRIVATE_KEY_TESTNET=
DEPLOYER_ADDRESS_TESTNET=

# Mainnet: create separately; do not reuse testnet key
DEPLOYER_PRIVATE_KEY_MAINNET=
DEPLOYER_ADDRESS_MAINNET=

# Deployed contracts (filled by scripts/phase0/deploy-registry.sh)
MEMORIA_REGISTRY_ADDRESS=

# --- 0G Compute ---
OG_COMPUTE_PROVIDER=
# OG_COMPUTE_API_KEY=          # from: 0g-compute-cli inference get-secret --provider <ADDR> --duration 0
# OG_COMPUTE_MODEL=qwen/qwen2.5-omni-7b
# OG_COMPUTE_PROXY_URL=https://compute-network-6.integratenetwork.work/v1/proxy/chat/completions
# Fund via: 0g-compute-cli deposit --amount 3   (minimum 3 0G on first deposit)

