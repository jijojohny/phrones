{
  "name": "phronesis",
  "version": "0.0.1",
  "private": true,
  "description": "Autonomous on-chain prediction-market fund on 0G deAIOS",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "ethers": "6.13.1"
    }
  },
  "scripts": {
    "setup:verify": "bash scripts/setup/verify-step1.sh",
    "setup:wallets": "bash scripts/setup/generate-wallets.sh",
    "setup:faucet-wallets": "bash scripts/setup/generate-faucet-wallets.sh",
    "setup:faucet-balances": "bash scripts/setup/check-faucet-balances.sh",
    "setup:faucet-addresses": "bash scripts/setup/print-faucet-addresses.sh",
    "setup:faucet-consolidate": "bash scripts/setup/consolidate-faucet-0g.sh",
    "setup:faucet-consolidate:dry": "bash scripts/setup/consolidate-faucet-0g.sh --dry-run",
    "setup:sync-storage": "bash scripts/setup/sync-storage-env.sh",
    "setup:storage-smoke": "bash scripts/setup/run-storage-smoke.sh",
    "setup:balance": "bash scripts/setup/check-balance.sh",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "phase0:deploy": "bash scripts/phase0/deploy-registry.sh",
    "phase0:markets": "pnpm --filter @phronesis/ingestion markets",
    "phase0:feed": "pnpm --filter @phronesis/ingestion start -- --duration=30 --markets=10",
    "phase0:audit": "pnpm --filter @phronesis/audit anchor",
    "phase0:compute": "bash scripts/phase0/smoke-compute.sh",
    "phase0:all": "pnpm phase0:deploy && pnpm phase0:feed && pnpm phase0:audit",
    "phase1:state": "pnpm --filter @phronesis/ingestion phase1 -- --duration=120 --markets=50",
    "phase1:fixture": "pnpm --filter @phronesis/ingestion phase1 -- --fixture --sentiment-only --markets=50",
    "phase1:sentiment": "pnpm --filter @phronesis/ingestion phase1 -- --sentiment-only --markets=50",
    "phase1:x402": "pnpm --filter @phronesis/ingestion phase1 -- --x402-demo --fixture --sentiment-only --markets=5",
    "phase2:cognitive": "pnpm --filter @phronesis/tee-core start -- --fixture",
    "phase2:paper": "pnpm --filter @phronesis/tee-core start -- --fixture --paper",
    "phase2:backtest": "pnpm --filter @phronesis/tee-core backtest",
    "phase2:audit": "pnpm --filter @phronesis/tee-core start -- --fixture --anchor",
    "phase2:test": "pnpm --filter @phronesis/tee-core test",
    "phase3:execute": "pnpm --filter @phronesis/execution start -- --dry-run",
    "phase3:live": "pnpm --filter @phronesis/execution start -- --live",
    "phase3:rotate-session": "pnpm --filter @phronesis/execution rotate-session",
    "phase3:check-session": "pnpm --filter @phronesis/execution rotate-session -- --check",
    "phase3:test": "pnpm --filter @phronesis/execution test",
    "phase4:deploy": "bash scripts/phase4/deploy-fund.sh",
    "phase4:encrypt": "pnpm --filter @phronesis/tokenization start -- encrypt-metadata",
    "phase4:authorize": "pnpm --filter @phronesis/tokenization start -- authorize",
    "phase4:executor": "pnpm --filter @phronesis/tokenization executor",
    "phase4:portal": "pnpm --filter @phronesis/tokenization portal",
    "phase4:test": "forge test --match-contract PhronesisFundTest",
    "phase5:preflight": "pnpm --filter @phronesis/ops preflight",
    "phase5:load-test": "pnpm --filter @phronesis/ops load-test",
    "phase5:compliance": "pnpm --filter @phronesis/ops start -- compliance",
    "phase5:ha-feed": "pnpm --filter @phronesis/ingestion ha-feed -- --fixture --duration=15",
    "phase5:transfer": "bash scripts/phase5/transfer-demo.sh",
    "phase5:all": "bash scripts/phase5/preflight-all.sh",
    "phase5:test": "forge test",
    "phase6:relay": "pnpm --filter @phronesis/relayer start -- --fixture",
    "phase6:relay:live": "pnpm --filter @phronesis/relayer start -- --live",
    "phase6:vaults": "pnpm --filter @phronesis/ingestion vaults",
    "phase6:transfer": "pnpm --filter @phronesis/tokenization oracle-transfer",
    "phase6:clone": "pnpm --filter @phronesis/tokenization oracle-transfer -- clone",
    "phase6:deploy-bridge": "bash scripts/phase6/deploy-intent-bridge.sh",
    "phase6:dashboard": "pnpm --filter @phronesis/operator-dashboard dev",
    "phase6:test": "forge test --match-contract 'Phronesis7857Test|IntentBridgeTest'"
  }
}
