# Documentation (local plans — keep .env.example tracked)
*.md

# =============================================================================
# Secrets & credentials — NEVER commit
# =============================================================================

# Environment files (keep .env.example as the template)
.env
.env.*
!.env.example

# Wallet / key material
wallets/
wallets.json
**/wallets.json
**/accounts.json
**/addresses.json
**/addresses.txt
*.key
*.pem
*.p12
*.keystore
**/keystore/**
mnemonic.txt
**/mnemonic*.txt
**/private_key*
**/seed.txt
**/recovery*.txt
**/id_rsa*
**/id_ed25519*

# API / service credentials
credentials.json
**/credentials.json
secrets.json
**/secrets.json
*.secret
*.credentials
service-account*.json
**/service-account*.json

# Polymarket / exchange API exports
**/polymarket*creds*
**/*api-secret*

# TEE / 0G Compute artifacts (may contain enclave keys or attestation quotes)
broker_attestation_report.json
**/*attestation*report*.json
**/attestation*.json
**/inference-secret*
**/compute-ledger*
**/app-sk-*
**/*compute*secret*

# Tokenization / ERC-7857 generated artifacts (ciphertext, sealed keys)
**/transfer-bundle.json
packages/tokenization/fixtures/encrypted-metadata.json
**/sealed-key*.json
**/*sealedKey*

# Session / relayer key material (policy JSON is OK — keys are not)
**/session-key*.json
**/*session-key*.json
**/*session_key*
**/relayer-key*

# Deployment state (may contain addresses tied to funded wallets)
.deployments.json
deployments.local.json
deployments/

# Foundry broadcast & cache (tx metadata; cache may store private keys)
broadcast/
cache/
out/
foundry/cache/
foundry/out/

# Foundry libs are vendored via git submodule — do not commit ad-hoc copies
lib/*
!lib/forge-std/

# Cloned / local tooling (has its own .env and node_modules)
tools/

