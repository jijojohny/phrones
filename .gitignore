# Documentation
*.md

# =============================================================================
# Secrets & credentials — NEVER commit
# =============================================================================

# Environment files (keep .env.example as the template)
.env
.env.*
!.env.example

# Wallet / key material
wallets/
wallets.json
**/wallets.json
*.key
*.pem
*.p12
*.keystore
**/keystore/**
mnemonic.txt
**/mnemonic*.txt
**/private_key*
**/id_rsa*
**/id_ed25519*

# API / service credentials
credentials.json
**/credentials.json
secrets.json
**/secrets.json
*.secret
*.credentials
service-account*.json
**/service-account*.json

# Polymarket / exchange API exports
**/polymarket*creds*
**/*api-secret*

# Deployment state (may contain addresses tied to funded wallets)
.deployments.json
deployments.local.json

# Foundry broadcast & cache (tx metadata; cache may store private keys)
broadcast/
cache/
out/
lib/

# Vendored / cloned tooling (has its own .env)
tools/0g-storage-ts-starter-kit/

# =============================================================================
# Dependencies & build
# =============================================================================

node_modules/
tools/**/node_modules/
dist/
build/
foundry/cache/
foundry/out/

# Logs & temp (setup scripts may echo sensitive data)
*.log
logs/
tmp/
*.bak
.env.bak.*

# OS / IDE
.DS_Store
.idea/
.vscode/
*.swp

# Foundry lock (optional local pin)
foundry.lock

# Keep empty broadcast folder placeholder if needed
!/broadcast/.gitkeep
