{
  "name": "@phronesis/tee-core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./pipeline": {
      "types": "./dist/pipeline/cognitive.d.ts",
      "import": "./dist/pipeline/cognitive.js"
    },
    "./strategy": {
      "types": "./dist/strategy/loader.d.ts",
      "import": "./dist/strategy/loader.js"
    },
    "./audit": {
      "types": "./dist/audit/redacted.d.ts",
      "import": "./dist/audit/redacted.js"
    },
    "./signing": {
      "types": "./dist/signing/eip712-intent.d.ts",
      "import": "./dist/signing/eip712-intent.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/kelly/sizer.test.ts && tsx src/allocator/qp-solver.test.ts",
    "start": "tsx src/cli.ts",
    "paper": "tsx src/cli.ts -- --paper",
    "backtest": "tsx src/cli.ts -- --backtest",
    "backtest:snapshot": "tsx src/cli.ts -- --backtest-snapshot --fixture",
    "encrypt-strategy": "tsx src/strategy/encrypt-cli.ts",
    "attestation-server": "tsx src/cli.ts -- --attestation-server --fixture"
  },
  "dependencies": {
    "@phronesis/audit": "workspace:*",
    "@phronesis/shared": "workspace:*",
    "ethers": "6.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
